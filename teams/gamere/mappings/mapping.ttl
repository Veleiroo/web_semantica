@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix : <http://example.org/def/gamere#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################
# PRAIA
#################################################

<#PraiaMapping>
a rr:TriplesMap ;

rml:logicalSource [
 rml:source "PraiasBandeiraAzul-2025-csv.csv" ;
 rml:referenceFormulation ql:CSV
];

rr:subjectMap [
 rr:template "http://example.org/resource/praia/{CÓDIGO CONCELLO}_{PRAIA}" ;
 rr:class :Praia
];

rr:predicateObjectMap [
 rr:predicate :nomePraia ;
 rr:objectMap [ rml:reference "PRAIA" ]
];

rr:predicateObjectMap [
 rr:predicate :lonxitude ;
 rr:objectMap [
  rml:reference "LONXITUDE" ;
  rr:datatype xsd:integer
 ]
];

rr:predicateObjectMap [
 rr:predicate :tipoArena ;
 rr:objectMap [ rml:reference "TIPO DE AREA" ]
];

rr:predicateObjectMap [
 rr:predicate :entorno ;
 rr:objectMap [ rml:reference "TIPO" ]
];

rr:predicateObjectMap [
 rr:predicate :url ;
 rr:objectMap [
  rml:reference "MaIS INFORMACIÓN EN TURGALICIA" ;
  rr:datatype xsd:anyURI
 ]
];

rr:predicateObjectMap [
 rr:predicate :situadaEn ;
 rr:objectMap [
  rr:template "http://example.org/resource/concello/{CÓDIGO CONCELLO}"
 ]
];

rr:predicateObjectMap [
 rr:predicate :estaEn ;
 rr:objectMap [
  rr:template "http://example.org/resource/ubicacion/{Coordenada X}_{Coordenada Y}"
 ]
].

#################################################
# UBICACION
#################################################

<#UbicacionMapping>
a rr:TriplesMap ;

rml:logicalSource [
 rml:source "PraiasBandeiraAzul-2025-csv.csv" ;
 rml:referenceFormulation ql:CSV
];

rr:subjectMap [
 rr:template "http://example.org/resource/ubicacion/{Coordenada X}_{Coordenada Y}" ;
 rr:class :Ubicacion
];

rr:predicateObjectMap [
 rr:predicate :coordenadasX ;
 rr:objectMap [
  rml:reference "Coordenada X" ;
  rr:datatype xsd:float
 ]
];

rr:predicateObjectMap [
 rr:predicate :coordenadasY ;
 rr:objectMap [
  rml:reference "Coordenada Y" ;
  rr:datatype xsd:float
 ]
];

rr:predicateObjectMap [
 rr:predicate :descripcion ;
 rr:objectMap [ rml:reference "LUGAR E PARROQUIA" ]
].

#################################################
# CONCELLO
#################################################

<#ConcelloMapping>
a rr:TriplesMap ;

rml:logicalSource [
 rml:source "PraiasBandeiraAzul-2025-csv.csv" ;
 rml:referenceFormulation ql:CSV
];

rr:subjectMap [
 rr:template "http://example.org/resource/concello/{CÓDIGO CONCELLO}" ;
 rr:class :Concello
];

rr:predicateObjectMap [
 rr:predicate :nameConcello ;
 rr:objectMap [ rml:reference "CONCELLO" ]
];

rr:predicateObjectMap [
 rr:predicate :codigoConcello ;
 rr:objectMap [
  rml:reference "CÓDIGO CONCELLO" ;
  rr:datatype xsd:integer
 ]
];

rr:predicateObjectMap [
 rr:predicate :perteneceA ;
 rr:objectMap [
  rr:template "http://example.org/resource/provincia/{CÓDIGO PROVINCIA}"
 ]
].

